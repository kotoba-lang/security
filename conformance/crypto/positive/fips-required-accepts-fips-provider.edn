{:case/id "fips-required-accepts-fips-provider"
 :case/check :envelope
 :policy {:kotoba.security/crypto-policy-version 1
          :mode :fips-required
          :hybrid-epoch-floor 1}
 :envelope {:envelope/algorithms [:aes-256-gcm]
