{:policy/type :kotoba.security/governance-production-qualification
 :policy/version 1
 :policy/status :implemented-awaiting-production-drill
 :operation/requirements #{:single-operation-capability :nonce-consumption
                           :subject-action-resource-digest-binding}
 :abac/axes #{:subject :resource :action :environment}
 :approval/requirements #{:digest-bound :signed :time-limited
                          :distinct-approvers :distinct-required-roles
                          :initiator-separated}
 :break-glass/requirements #{:bounded-expiry :incident-id :signed-reason
                             :closed-status :independent-signed-post-review
                             :review-deadline}
 :shared-gate "policy/production-evidence-plane.edn"
 :non-claims #{:admin-role-is-not-unbounded-authority
               :self-approval-is-not-independent-approval
               :break-glass-is-not-policy-bypass
               :unit-drill-is-not-production-e4}}
