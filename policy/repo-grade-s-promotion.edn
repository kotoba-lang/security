{:policy/type :kotoba.security/repo-grade-s-promotion
 :policy/version 1
 :policy/prerequisite "policy/repo-grade-a-promotion.edn"
 :profile/requirements {:score-minimum 90 :critical-control-minimum 80
                        :maturity-minimum :L4 :evidence-minimum :E5
                        :release-gate :pass :residual-critical-gaps 0
                        :grade :S}
 :continuous-verification/requirements
 #{:independent-organization :continuous-mode :artifact-binding
   :all-critical-controls :all-grade-a-evidence-heads
   :multi-region :multi-provider :minimum-window :sampling-slo
   :fresh-signed-report :zero-unresolved-failures}
 :non-claims #{:internal-ci-is-not-e5 :periodic-red-team-is-not-continuous-e5
               :single-provider-monitoring-is-not-independent-e5
               :fixture-e5-is-not-production-grade-s}}
