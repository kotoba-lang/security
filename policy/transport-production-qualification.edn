{:policy/type :kotoba.security/transport-production-qualification
 :policy/version 1
 :policy/status :implemented-awaiting-production-ca
 :transport/requirements #{:tls-1.3 :mandatory-mtls :peer-identity-binding
                           :trusted-certificate :online-revocation-check}
 :workload-identity/requirements #{:spiffe-uri :issuer :audience
                                   :short-lived :active-revocation-status}
 :ca/requirements #{:hardware-backed :attestation :non-export
                    :sign-operation :rotation :outage-fail-closed}
 :rotation/requirements #{:overlap :promotion :old-certificate-revocation
                          :revoked-rollback-denial}
 :shared-gate "policy/production-evidence-plane.edn"
 :non-claims #{:tls-config-is-not-production-mtls-evidence
               :self-signed-fixture-is-not-production-ca
               :apple-keychain-is-not-ca-hsm-qualification}}
