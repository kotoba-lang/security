                 :production-key-and-certificate-rotation]}
  :S {:score/minimum 90
      :critical-control/minimum 80
      :maturity/minimum :L4
      :evidence/minimum :E5
      :release-gate/allowed #{:pass}
      :residual-critical-gaps 0
      :required [:independent-continuous-verification
                 :continuous-control-monitoring
                 :automated-containment-and-known-clean-restore
                 :independent-red-team-and-retest
                 :multi-region-provider-failure-drills]}}

