{:model/type :kotoba.security/assurance-model
 :model/version 1
 :model/scope :kotoba-lang/repo-wide
 :model/rule "No scalar score is a probability of safety or a release authorization."
 :score {:range [0 100]
         :name "Security Control Maturity"
         :aggregation :weighted-inner-product
         :weights {:zero-trust 1/18 :capability 1/18 :pqc 1/18 :hsm 1/18
                   :monitoring-recovery 1/18
                   :transport-confidentiality-integrity 1/18
                   :anti-impersonation 1/18 :abac 1/18
                   :authorized-process-abuse 1/18 :software-tamper 1/18
                   :private-key-theft 1/18 :memory-corruption 1/18
                   :dos 1/18 :information-flow 1/18 :insider-threat 1/18
                   :unknown-compromise 1/18 :quantum-communication 1/18
                   :unrecoverable-loss 1/18}}
 :maturity [{:id :L0 :meaning :absent}
            {:id :L1 :meaning :designed}
            {:id :L2 :meaning :implemented-locally}
            {:id :L3 :meaning :boundary-enforced-ci-negative-tested}
            {:id :L4 :meaning :production-qualified-continuously-drilled}]
 :evidence [{:id :E0 :meaning :assertion-only}
            {:id :E1 :meaning :design-or-adr}
            {:id :E2 :meaning :unit-test}
            {:id :E3 :meaning :integration-negative-test-ci}
            {:id :E4 :meaning :signed-production-receipt}
            {:id :E5 :meaning :independent-continuous-verification}]
 :grades [{:id :S :minimum 90} {:id :A :minimum 80}
          {:id :B :minimum 60} {:id :C :minimum 40}
          {:id :D :minimum 20} {:id :F :minimum 0}]
 :release-gates [:pass :partial :fail :blocked :not-applicable]
 :critical-controls
 #{:capability :hsm :transport-confidentiality-integrity :anti-impersonation
   :software-tamper :private-key-theft :unknown-compromise
   :unrecoverable-loss}
 :caps [{:when :any-critical-below-40 :maximum-grade :C}
        {:when :any-critical-below-20 :release-gate :fail}
        {:when :missing-E4-production-evidence :release-gate :partial}
        {:when :unresolved-critical-gap :release-gate :partial}]
 :heatmap {:green {:minimum 80 :meaning :implemented-tested-or-qualified}
           :yellow {:minimum 60 :meaning :implemented-residual-gap}
           :orange {:minimum 40 :meaning :partial-profile-dependent}
           :red {:minimum 0 :meaning :absent-or-limited}
           :gray {:meaning :not-applicable-or-accepted-non-goal}}
 :required-report-fields
 [:assurance/score :assurance/maturity :assurance/grade
  :assurance/release-gate :assurance/evidence
  :assurance/residual-critical-gaps]}
