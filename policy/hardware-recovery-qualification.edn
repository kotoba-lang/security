{:policy/type :kotoba.security/hardware-recovery-qualification
 :policy/version 1
 :policy/status :implemented-awaiting-production-evidence
 :hardware {:required #{:hardware-backed :vendor-attestation :non-export
                        :sign :kem :rotation :outage-fail-closed}
            :evidence-control :hsm}
 :recovery {:minimum-regions 2
            :threshold {:minimum 2 :distinct-members true
                        :hardware-protected-shares true}
            :required #{:encrypted-immutable-backups :destructive-restore
                        :digest-verification :bounded-rto :bounded-rpo}
            :evidence-control :unrecoverable-loss}
 :shared-gate "policy/production-evidence-plane.edn"
 :non-claims #{:apple-secure-enclave-is-not-general-hsm
               :simulated-regions-are-not-production-regions
               :unit-test-e4-is-not-operational-e4}}
