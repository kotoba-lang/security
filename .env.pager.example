# Kotoba security pager / alert delivery — EXAMPLE ONLY
# Copy to a gitignored local env file or export in your shell.
# NEVER commit real webhook URLs, tokens, or routing keys.

# Optional: HTTP(S) endpoint that accepts POST application/json
# (Slack incoming webhook, PagerDuty Events API v2 enqueue, or custom receiver).
# When unset, scripts report "webhook skipped" honestly and still use the file sink.
KOTOBA_SECURITY_ALERT_WEBHOOK=

# Optional: force vendor payload shape (slack | pagerduty | generic).
# When unset, URL heuristics apply (hooks.slack.com → slack, events.pagerduty.com → pagerduty).
KOTOBA_SECURITY_ALERT_SINK=

# Optional: PagerDuty Events API v2 routing key (only when using pagerduty sink).
# Never invent; load from kagi/Keychain. Omitted from payload when empty.
KOTOBA_SECURITY_PAGERDUTY_ROUTING_KEY=

# Optional documentation-only fields
# KOTOBA_SECURITY_ALERT_CHANNEL=#security-oncall-example
