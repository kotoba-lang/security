  {:gate/id :G-010
   :gate/control :unrecoverable-loss
   :gate/status :partially-resolved
   :gate/affected-repos [:kotoba-lang :kotobase :compiler :kagi]
   :gate/summary "Disaster recovery: independent encrypted backups, threshold-key recovery, and destructive restore drill; gate closes with production-region independence evidence."
   :gate/owner :disaster-recovery-owner
   :gate/owner-email "jun@gftd.group"
   :gate/timeline {:start "2026-Q3" :target-close "2026-Q4-end"}
   :gate/executable-criteria
   [{:criterion/id "G-010-EX-001"
     :criterion/name "Independent encrypted backups"
     :criterion/description "At least 2 independent backup sites (different clouds, different regions, different providers); backups are encrypted at-rest; each site can restore independently without other sites"
     :criterion/executable-test
     "cd kotoba-lang/security && bb scripts/verify-backup-independence.bb --site-a us-east-1 --site-b eu-west-1 && grep -q 'sites-independent: true' backup-verify.edn"
     :criterion/acceptance-value true
     :criterion/evidence-sink :EV-dr-backup-independence}
    {:criterion/id "G-010-EX-002"
     :criterion/name "Threshold-key recovery (M-of-N)"
     :criterion/description "Backup encryption keys are split using threshold scheme (e.g., 2-of-3); any M keys can recover without N; recovery succeeds with M keys, fails with M-1"
     :criterion/executable-test
     "cd kotoba-lang/kagi && bb scripts/test-threshold-recovery.bb --threshold 2 --total 3 && grep -q 'threshold-met: true' threshold-test-report.edn && grep -q 'below-threshold: denied' threshold-test-report.edn"
     :criterion/acceptance-value true
     :criterion/evidence-sink :EV-dr-threshold-key}
    {:criterion/id "G-010-EX-003"
     :criterion/name "Destructive restore drill with RTO/RPO measurement"
     :criterion/description "Full restore from encrypted backup is executed (destructive: existing data overwritten); RTO and RPO are measured; digest verification passes; recovery is complete"
     :criterion/executable-test
     "cd kotoba-lang/security && bb scripts/destructive-restore-drill.bb --backup-site-a us-east-1-backup.tar.gz.enc --backup-site-b eu-west-1-backup.tar.gz.enc --threshold-keys 2 && jq '.digest-verified, .rto-ms, .rpo-ms, .recovery-complete' dr-drill-receipt.edn"
     :criterion/acceptance-value true
     :criterion/evidence-sink :EV-dr-restore-drill}
    {:criterion/id "G-010-EX-004"
     :criterion/name "Backup replication verification"
     :criterion/description "Each backup is replicated to all sites; digest comparison confirms bit-identical copies; replication lag is measured and below SLA"
     :criterion/executable-test
     "cd kotoba-lang/security && bb scripts/verify-backup-replication.bb --sites us-east-1 eu-west-1 && grep -q 'all-digests-match: true' replication-verify.edn && jq '.max-replication-lag-ms' replication-verify.edn"
     :criterion/acceptance-value true
     :criterion/evidence-sink :EV-dr-replication}]
