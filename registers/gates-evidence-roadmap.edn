     :criterion/acceptance-value true
     :criterion/evidence-sink :EV-ir-tabletop}
    {:criterion/id "G-008-EX-004"
     :criterion/name "Known-clean restore with measured RTO/RPO"
     :criterion/description "Destructive restore from known-clean backup is executed; RTO and RPO are measured and compared against SLA; metrics are recorded in drill receipt"
