   [{:risk/id "R-DR-001" :risk/desc "Backup encryption key single point of failure" :risk/mitigation "Threshold-key split + independent custody"}
    {:risk/id "R-DR-002" :risk/desc "Replication fails silently" :risk/mitigation "Replication verification + alerting"}
    {:risk/id "R-DR-003" :risk/desc "Restore RTO exceeds acceptable window" :risk/mitigation "Restore drill + backup optimization"}
    {:risk/id "R-DR-004" :risk/desc "Production region infrastructure fails completely" :risk/mitigation "Multi-region deployment + failover test"}]
   :gate/dependencies [:G-001 :G-002]
   :gate/blocks [:production-qualified]}]

 :roadmap/shared-evidence-procedures
 [{:procedure/id "PROC-HARDWARE-TEST"
   :procedure/name "Real Hardware HSM Test Protocol"
   :procedure/applies-to [:G-004]
   :procedure/steps
   ["1. Provision real hardware (YubiKey 5, TPM 2.0, or equivalent certified module)"
    "2. Initialize hardware with test keypair"
    "3. Attempt private key export (negative test) - MUST FAIL"
    "4. Verify attestation certificate chain - MUST SUCCEED"
    "5. Execute signing operation 100 times - MEASURE latency"
    "6. Perform key rotation (generate new key, revoke old) - MEASURE downtime"
    "7. Simulate HSM unavailability (power off, network block) - VERIFY fail-closed"
    "8. Record all measurements and receipts in hardware-qualification-receipt.edn"
    "9. Upload receipt to evidence/ directory with date stamp"]
   :procedure/equipment-requirements ["Real HSM hardware (not software emulation)"
                                      "Hardware attestation root certificate"
                                      "Private key custody procedure (secure envelope)"]}

  {:procedure/id "PROC-CRYPTO-VECTOR-TEST"
   :procedure/name "Cryptographic Algorithm Vector Test"
   :procedure/applies-to [:G-003]
   :procedure/steps
   ["1. Generate ML-KEM-768 + X25519 test vectors (3+ independent implementations)"
    "2. Execute envelope seal/unseal for each vector - MEASURE performance"
    "3. Verify algorithm negotiation returns :envelope/algorithm metadata"
    "4. Test downgrade denial: attempt seal with X25519-only when ML-KEM-768 mandatory - MUST DENY"
    "5. Test rollback denial: attempt to use old v1 envelope format when v2 is current - MUST DENY"
    "6. Verify SBOM includes ML-KEM-768 library + version"
    "7. Record all test results and algorithm metadata in pqc-vector-receipt.edn"]}

  {:procedure/id "PROC-TLS-ROTATION-DRILL"
   :procedure/name "Certificate Rotation Drill"
   :procedure/applies-to [:G-005]
   :procedure/steps
   ["1. Deploy old certificate and establish connection baseline"
    "2. Begin new certificate deployment in parallel (overlap period)"
    "3. Measure overlap duration where both certs are valid"
    "4. Revoke old certificate (OCSP/CRL update)"
    "5. Attempt connection with old cert - MUST FAIL"
    "6. Attempt connection with new cert - MUST SUCCEED"
    "7. Verify all dependent services reconnected successfully"
    "8. Measure total rotation time and record in certificate-rotation-receipt.edn"
    "9. Record revocation status confirmation from OCSP responder or CRL"]}

  {:procedure/id "PROC-INCIDENT-RESPONSE-TABLETOP"
   :procedure/name "Incident Response Tabletop Drill"
   :procedure/applies-to [:G-008]
   :procedure/steps
   ["1. Select incident scenario (e.g., compromised package signer)"
    "2. Notify response team and start timer"
    "3. Present incident scenario with limited information (simulate detection)"
    "4. Execute response playbook step-by-step (investigation, containment, communication)"
    "5. Record decision points and response times"
    "6. Verify ordered containment executed (grants revoked, new operations denied)"
    "7. Verify immutable telemetry was updated"
    "8. End drill and conduct postmortem (what worked, what was slow, what we missed)"
    "9. Write postmortem document and record in evidence/ir-tabletop-postmortem.md"]}

  {:procedure/id "PROC-DESTRUCTIVE-RESTORE"
   :procedure/name "Destructive Restore Drill (Disaster Recovery)"
   :procedure/applies-to [:G-008 :G-010]
   :procedure/steps
   ["1. Create full backup of production data (encrypted)"
    "2. Replicate backup to 2+ independent sites"
    "3. Select a test environment (separate from production)"
    "4. Destroy test environment data (simulate catastrophic failure)"
    "5. Initiate restore from backup (use threshold-key recovery for G-010)"
    "6. Measure RTO (Recovery Time Objective) - time from restore start to data ready"
    "7. Measure RPO (Recovery Point Objective) - age of recovered data"
    "8. Verify data integrity using digest comparison (SHA-256 or stronger)"
    "9. Verify no downgrade of security (e.g., encryption level maintained)"
    "10. Record RTO/RPO/digest/recovery status in destructive-restore-drill-receipt.edn"
    "11. Compare against SLA and record pass/fail"]}]

