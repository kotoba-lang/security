  {:gate/id :G-005
   :gate/control :transport-confidentiality-integrity
   :gate/status :partially-resolved
   :gate/affected-repos [:kototama :aiueos :kotobase :kagi]
   :gate/summary "Mutual TLS with peer verification, certificate rotation, revocation checks, and forged-publisher denial; gate closes with production CA/HSM rotation evidence."
   :gate/owner :transport-owner
   :gate/owner-email "jun@gftd.group"
   :gate/timeline {:start "2026-Q3" :target-close "2026-Q4-mid"}
   :gate/executable-criteria
   [{:criterion/id "G-005-EX-001"
     :criterion/name "Mutual TLS enforcement (mTLS)"
     :criterion/description "Client certificate is required (not optional); server certificate is verified; both parties verify peer identity; connection denied on missing/invalid certificate"
     :criterion/executable-test
     "cd kotoba-lang/security && bb scripts/test-mtls-enforcement.bb --server-cert server.pem --client-cert client.pem --skip-client && echo DENIED || echo FAIL"
     :criterion/acceptance-value true
     :criterion/evidence-sink :EV-transport-mtls}
    {:criterion/id "G-005-EX-002"
     :criterion/name "TLS downgrade denial"
     :criterion/description "TLS 1.3 or higher is enforced; TLS 1.2 and below are denied; cipher suites are restricted to authenticated encryption with PFS"
     :criterion/executable-test
     "cd kotoba-lang/security && bb scripts/test-tls-downgrade-denial.bb --min-version 1.3 && grep -q 'tls-1.2: denied' tls-denial-report.edn"
     :criterion/acceptance-value true
     :criterion/evidence-sink :EV-transport-downgrade-denial}
    {:criterion/id "G-005-EX-003"
     :criterion/name "Certificate rotation drill"
     :criterion/description "Old certificate is replaced; old-cert connections are denied; new-cert connections succeed; overlap period is measured; old-cert revocation is confirmed"
     :criterion/executable-test
     "cd kotoba-lang/security && bb scripts/certificate-rotation-drill.bb --old-cert old.pem --new-cert new.pem && jq '.overlap-duration-ms, .revocation-confirmed' cert-rotation-report.edn"
     :criterion/acceptance-value true
     :criterion/evidence-sink :EV-transport-cert-rotation}
    {:criterion/id "G-005-EX-004"
     :criterion/name "Forged publisher denial (negative test)"
     :criterion/description "Connection with a valid certificate but from an untrusted publisher (not in trust anchor list) is denied; denial is logged with publisher fingerprint"
     :criterion/executable-test
     "cd kotoba-lang/security && bb scripts/test-forged-publisher-denial.bb --untrusted-cert untrusted.pem && grep -q 'forged-publisher: denied' publisher-denial-report.edn"
     :criterion/acceptance-value true
     :criterion/evidence-sink :EV-transport-publisher-denial}
    {:criterion/id "G-005-EX-005"
     :criterion/name "Revocation check enforcement"
     :criterion/description "OCSP or CRL revocation checks are performed; revoked certificate connections are denied; revocation status is cached or re-checked per SLA"
     :criterion/executable-test
     "cd kotoba-lang/security && bb scripts/test-revocation-enforcement.bb --revoked-cert revoked.pem && grep -q 'revoked: denied' revocation-report.edn"
     :criterion/acceptance-value true
     :criterion/evidence-sink :EV-transport-revocation}]
