  {:gate/id :G-008
   :gate/control :unknown-compromise
   :gate/status :partially-resolved
   :gate/affected-repos [:kotoba :kototama :kotobase :aiueos :kagi]
   :gate/summary "Incident response: rewrite-detecting telemetry, automated containment, and destructive restore drill with measured RTO/RPO; gate closes with live remote authorities and production evidence."
   :gate/owner :incident-response-owner
   :gate/owner-email "jun@gftd.group"
   :gate/timeline {:start "2026-Q3" :target-close "2026-Q4-end"}
   :gate/executable-criteria
   [{:criterion/id "G-008-EX-001"
     :criterion/name "Immutable remote telemetry (hash-chained)"
     :criterion/description "Telemetry entries are content-addressed and hash-linked; entries are appended to immutable log; log is replicated to independent remote authority; local rewrite is detectable"
     :criterion/executable-test
     "cd kotoba-lang/security && bb scripts/test-telemetry-immutability.bb --local-log telemetry.log --remote-log https://audit.example.com/logs && grep -q 'hash-chain: verified' telemetry-report.edn"
     :criterion/acceptance-value true
     :criterion/evidence-sink :EV-ir-telemetry}
    {:criterion/id "G-008-EX-002"
     :criterion/name "Automated containment (ordered containment)"
     :criterion/description "Upon detection of compromise (forged artifact, revoked key, policy violation), kagi executes ordered containment; denies new operations with reason; existing grants are revoked in dependency order"
     :criterion/executable-test
     "cd kotoba-lang/kagi && bb scripts/test-automated-containment.bb --compromised-signer signer.pub && grep -q 'containment-executed: true' containment-report.edn && grep -q 'dependent-grants-revoked: [0-9]' containment-report.edn"
     :criterion/acceptance-value true
     :criterion/evidence-sink :EV-ir-containment}
    {:criterion/id "G-008-EX-003"
