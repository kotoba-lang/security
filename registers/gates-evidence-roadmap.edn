   :gate/summary "HSM non-exportability, attestation, signing/KEM rotation, and fail-closed outage behavior; gate closes only with real hardware test evidence (software emulation insufficient)."
   :gate/owner :kagi-owner
   :gate/owner-email "jun@gftd.group"
   :gate/timeline {:start "2026-Q3" :target-close "2026-Q4-mid"}
   :gate/executable-criteria
   [{:criterion/id "G-004-EX-001"
     :criterion/name "Hardware non-exportability verification"
     :criterion/description "Real HSM (YubiKey, PKCS#11, TPM) is used; private key never leaves device in plaintext form; export attempt on real hardware fails with provider denial receipt"
     :criterion/executable-test
     "cd kotoba-lang/kagi && ./scripts/test-hsm-non-export.sh --device /dev/tpm0 --attestation && grep -q 'non-exported: true' hardware-test-report.txt"
     :criterion/acceptance-value true
     :criterion/evidence-sink :EV-hsm-non-export}
    {:criterion/id "G-004-EX-002"
     :criterion/name "Verified hardware attestation"
     :criterion/description "HSM attestation certificate chain is validated; attestation proves hardware manufacturer; failed attestation denies key use"
     :criterion/executable-test
     "cd kotoba-lang/kagi && bb scripts/verify-hsm-attestation.bb --certificate hardware-attestation.pem --root-ca root-cert.pem && echo VERIFIED || exit 1"
     :criterion/acceptance-value true
     :criterion/evidence-sink :EV-hsm-attestation}
    {:criterion/id "G-004-EX-003"
     :criterion/name "Signing and KEM rotation drill"
     :criterion/description "Old HSM key is replaced with new key; old-key signing is denied; new-key signing succeeds; no downtime measured"
     :criterion/executable-test
     "cd kotoba-lang/kagi && bb scripts/hsm-rotation-drill.bb --old-slot 1 --new-slot 2 && grep -q 'rotation-time-ms: [0-9]' rotation-drill-report.edn"
     :criterion/acceptance-value true
     :criterion/evidence-sink :EV-hsm-rotation-drill}
    {:criterion/id "G-004-EX-004"
     :criterion/name "Fail-closed outage behavior"
     :criterion/description "When HSM is unavailable (power off, network down, service down), dependent operations fail closed (denied, not with fallback to software key); outage is measured and logged"
     :criterion/executable-test
