     :criterion/evidence-sink :EV-pqc-prod-envelope}
    {:criterion/id "G-003-EX-002"
     :criterion/name "Algorithm downgrade denial"
     :criterion/description "Cryptographic policy rejects requests to use lower-security modes (e.g., X25519-only when ML-KEM-768 is mandatory); denial paths are tested for each repo boundary"
     :criterion/executable-test
     "cd kotoba-lang/security && bb scripts/test-pqc-downgrade-denial.bb --policy policy/crypto-policy.edn --algorithm-downgrade && echo PASS || echo FAIL"
     :criterion/acceptance-value true
     :criterion/evidence-sink :EV-pqc-downgrade-tests}
    {:criterion/id "G-003-EX-003"
     :criterion/name "Envelope rotation and rollback proof"
     :criterion/description "Key rotation drills demonstrate old envelope format rejection and new envelope acceptance; rollback to old algorithm is denied"
     :criterion/executable-test
     "cd kotoba-lang/security && bb scripts/pqc-rotation-drill.bb --old-envelope vectors/hybrid-x25519-mlkem768-v1.edn --new-envelope vectors/hybrid-x25519-mlkem768-v2.edn && grep -q 'rollback-denied: true' drill-report.edn"
     :criterion/acceptance-value true
