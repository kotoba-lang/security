   :gate/status :partially-resolved
   :gate/affected-repos [:kotoba :kotoba-lang :kototama :kotobase :aiueos :compiler :kagi]
   :gate/summary "PQC hybrid envelope integration outside kagi; gate closes only when production data path executes ML-KEM-768+classical hybrid, rejects algorithm downgrades, and passes rotation/rollback drill."
   :gate/owner :security-owner
   :gate/owner-email "jun@gftd.group"
   :gate/timeline {:start "2026-Q3" :target-close "2026-Q4-end"}
   :gate/executable-criteria
   [{:criterion/id "G-003-EX-001"
     :criterion/name "Hybrid KEM envelope production integration"
     :criterion/description "ML-KEM-768+X25519 (or PQ equivalent) envelope is the default on the production data path (not optional/fallback mode); kem operations return structured :envelope/provider + :envelope/algorithm metadata"
     :criterion/executable-test
     "cd kotoba-lang/security && bb scripts/verify-pqc-production-path.bb --envelope-live --provider-metadata && jq '.algorithm | select(. == \"ML-KEM-768\")' <test-output.json"
