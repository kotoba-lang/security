{:register/type :kotoba.security/on-call-roster
 :register/version 1
 :register/status :example-only
 :register/notes
 "EXAMPLE roster only — contacts use @example.invalid (RFC 2606). Not a live
  human rotation. Fill real contacts out-of-band; never commit personal emails
  or phone numbers. Live Slack/PagerDuty URLs stay in kagi/Keychain, not git."

 :roles
 [{:role :primary
   :title "Primary on-call"
   :contact "security-primary@example.invalid"
   :escalation-path "secondary"
   :timezone "UTC"
   :coverage "24x7 example"}
  {:role :secondary
   :title "Secondary on-call"
   :contact "security-secondary@example.invalid"
   :escalation-path "security-owner"
   :timezone "UTC"
   :coverage "24x7 example"}
  {:role :security-owner
   :title "Security owner"
   :contact "security-owner@example.invalid"
   :escalation-path nil
   :timezone "UTC"
   :coverage "business-hours + SEV-1 page"}
  {:role :package-owner
   :title "Package owner"
   :contact "package-owner@example.invalid"
   :timezone "UTC"}
  {:role :crypto-owner
   :title "Crypto owner"
   :contact "crypto-owner@example.invalid"
   :timezone "UTC"}
  {:role :operations-owner
   :title "Operations owner"
   :contact "operations-owner@example.invalid"
   :timezone "UTC"}]

 :severity->channel
 {:SEV-1 {:channel "#security-oncall-example"
          :page? true
          :roles [:primary :secondary :security-owner]
          :ack-minutes 5
          :escalate-minutes 15}
  :SEV-2 {:channel "#security-oncall-example"
          :page? true
          :roles [:primary :operations-owner]
          :ack-minutes 15
          :escalate-minutes 30}
  :SEV-3 {:channel "#security-notify-example"
          :page? false
          :roles [:operations-owner]
          :ack-minutes 240
          :escalate-minutes 1440}
  :SEV-4 {:channel "#security-notify-example"
          :page? false
          :roles [:security-owner]
          :ack-minutes 10080
          :escalate-minutes nil}}

 :alert-routing
 [{:alert/name "trusted-signer-verification-failure"
   :severity :SEV-1
   :roles [:primary :package-owner :security-owner]}
  {:alert/name "host-capability-denial-spike"
   :severity :SEV-2
   :roles [:primary :operations-owner]}
  {:alert/name "monitoring-heartbeat"
   :severity :SEV-4
   :roles [:operations-owner]
   :page? false}
  {:alert/name "pager-wiring-smoke"
   :severity :SEV-3
   :roles [:operations-owner]
   :page? false}]

 :escalation
 {:primary-unack-minutes 15
  :secondary-unack-minutes 30
  :security-owner-unack-minutes 45
  :freeze-releases-on #{:SEV-1}}

 :env
 {:webhook "KOTOBA_SECURITY_ALERT_WEBHOOK"
  :sink "KOTOBA_SECURITY_ALERT_SINK"
  :pagerduty-routing-key "KOTOBA_SECURITY_PAGERDUTY_ROUTING_KEY"
  :channel "KOTOBA_SECURITY_ALERT_CHANNEL"}}
